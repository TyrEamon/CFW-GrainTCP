{
  "$schema": "https://json.schemastore.org/wrangler",
  "name": "proxylink-web",
  "main": "frontend-worker.js",
  "compatibility_date": "2026-06-14",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "proxylinks.mtcacg.top/*",
      "zone_name": "mtcacg.top"
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true
    }
  }
}
